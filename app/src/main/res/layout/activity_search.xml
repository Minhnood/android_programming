<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <!-- Search Header -->
    <LinearLayout
        android:id="@+id/llSearchHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_circle_dark"
            android:padding="10dp"
            android:src="@drawable/ic_back"
            app:tint="@color/white"
            android:contentDescription="@string/back" />

        <EditText
            android:id="@+id/edtSearch"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_search_input"
            android:hint="@string/search_hint"
            android:paddingHorizontal="16dp"
            android:textColor="@color/white"
            android:textColorHint="@color/text_secondary"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:maxLines="1"
            android:importantForAutofill="no" />
    </LinearLayout>

    <!-- Content Area -->
    <ScrollView
        android:id="@+id/svHistory"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/llSearchHeader">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/recent_searches"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/cgRecent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp">
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Skyline R34"
                    app:chipBackgroundColor="@color/jdm_grey"
                    android:textColor="@color/white"
                    style="@style/Widget.MaterialComponents.Chip.Action" />
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Supra MK4"
                    app:chipBackgroundColor="@color/jdm_grey"
                    android:textColor="@color/white"
                    style="@style/Widget.MaterialComponents.Chip.Action" />
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Silvia S15"
                    app:chipBackgroundColor="@color/jdm_grey"
                    android:textColor="@color/white"
                    style="@style/Widget.MaterialComponents.Chip.Action" />
            </com.google.android.material.chip.ChipGroup>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="@string/popular_brands"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <GridLayout
                android:id="@+id/glBrands"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:layout_marginTop="12dp">

                <TextView
                    android:id="@+id/brandNissan"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_search_input"
                    android:gravity="center"
                    android:text="NISSAN"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/brandToyota"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_search_input"
                    android:gravity="center"
                    android:text="TOYOTA"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/brandMazda"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_search_input"
                    android:gravity="center"
                    android:text="MAZDA"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/brandHonda"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_search_input"
                    android:gravity="center"
                    android:text="HONDA"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/brandMitsubishi"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_search_input"
                    android:gravity="center"
                    android:text="MITSUBISHI"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/brandSubaru"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_search_input"
                    android:gravity="center"
                    android:text="SUBARU"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />
            </GridLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Results List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvResults"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        android:padding="8dp"
        android:clipToPadding="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/llSearchHeader"
        tools:listitem="@layout/item_car_grid" />

    <!-- No results -->
    <LinearLayout
        android:id="@+id/llNoResults"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/llSearchHeader">

        <ImageView
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:alpha="0.2"
            android:src="@drawable/ic_car_placeholder"
            app:tint="@color/white"
            android:contentDescription="Empty" />

        <TextView
            android:id="@+id/tvNoResults"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/no_results"
            android:textColor="@color/text_secondary"
            android:textSize="15sp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>