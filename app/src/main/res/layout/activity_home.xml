                                <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:padding="16dp" android:scaleType="fitCenter" tools:srcCompat="@tools:sample/avatars" />
                            </com.google.android.material.card.MaterialCardView>
                            <ImageView android:layout_width="28dp" android:layout_height="28dp" android:layout_marginTop="8dp" android:layout_marginEnd="8dp" android:padding="6dp" android:src="@android:drawable/ic_menu_myplaces" app:layout_constraintEnd_toEndOf="@+id/imgHot1" app:layout_constraintTop_toTopOf="@+id/imgHot1" app:tint="#FF4B4B" />
                            <TextView android:id="@+id/tvTitleHot1" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:ellipsize="end" android:maxLines="2" android:text="Sản phẩm Hot 1" android:textColor="#333333" android:textSize="14sp" android:textStyle="bold" app:layout_constraintTop_toBottomOf="@id/imgHot1" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="$299.00" android:textColor="#111111" android:textSize="16sp" android:textStyle="bold" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/tvTitleHot1" />
                            <com.google.android.material.card.MaterialCardView android:layout_width="32dp" android:layout_height="32dp" app:cardBackgroundColor="#222222" app:cardCornerRadius="10dp" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toBottomOf="@id/tvTitleHot1">
                                <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:src="@android:drawable/ic_input_add" app:tint="#FFFFFF" />
                            </com.google.android.material.card.MaterialCardView>
