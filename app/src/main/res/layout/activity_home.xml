                            </com.google.android.material.card.MaterialCardView>
                            <ImageView android:layout_width="28dp" android:layout_height="28dp" android:layout_marginTop="8dp" android:layout_marginEnd="8dp" android:padding="6dp" android:src="@android:drawable/ic_menu_myplaces" app:layout_constraintEnd_toEndOf="@+id/imgHot2" app:layout_constraintTop_toTopOf="@+id/imgHot2" app:tint="#FF4B4B" />
                            <TextView android:id="@+id/tvTitleHot2" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:ellipsize="end" android:maxLines="2" android:text="Sản phẩm Hot 2" android:textColor="#333333" android:textSize="14sp" android:textStyle="bold" app:layout_constraintTop_toBottomOf="@id/imgHot2" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="$199.00" android:textColor="#111111" android:textSize="16sp" android:textStyle="bold" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/tvTitleHot2" />
                            <com.google.android.material.card.MaterialCardView android:layout_width="32dp" android:layout_height="32dp" app:cardBackgroundColor="#222222" app:cardCornerRadius="10dp" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toBottomOf="@id/tvTitleHot2">
                                <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:src="@android:drawable/ic_input_add" app:tint="#FFFFFF" />
                            </com.google.android.material.card.MaterialCardView>
                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="170dp" android:layout_height="wrap_content" android:layout_margin="8dp" app:cardBackgroundColor="#FFFFFF" app:cardCornerRadius="20dp" app:cardElevation="6dp" app:strokeColor="#1A000000" app:strokeWidth="1dp">
                        <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="12dp">
                            <com.google.android.material.card.MaterialCardView android:id="@+id/imgHot3" android:layout_width="match_parent" android:layout_height="130dp" app:cardBackgroundColor="#F5F5F5" app:cardCornerRadius="12dp" app:cardElevation="0dp" app:layout_constraintTop_toTopOf="parent">
                                <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:padding="16dp" android:scaleType="fitCenter" tools:srcCompat="@tools:sample/avatars" />
                            </com.google.android.material.card.MaterialCardView>
                            <ImageView android:layout_width="28dp" android:layout_height="28dp" android:layout_marginTop="8dp" android:layout_marginEnd="8dp" android:padding="6dp" android:src="@android:drawable/ic_menu_myplaces" app:layout_constraintEnd_toEndOf="@+id/imgHot3" app:layout_constraintTop_toTopOf="@+id/imgHot3" app:tint="#FF4B4B" />
                            <TextView android:id="@+id/tvTitleHot3" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:ellipsize="end" android:maxLines="2" android:text="Sản phẩm Hot 3" android:textColor="#333333" android:textSize="14sp" android:textStyle="bold" app:layout_constraintTop_toBottomOf="@id/imgHot3" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="$99.00" android:textColor="#111111" android:textSize="16sp" android:textStyle="bold" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/tvTitleHot3" />
                            <com.google.android.material.card.MaterialCardView android:layout_width="32dp" android:layout_height="32dp" app:cardBackgroundColor="#222222" app:cardCornerRadius="10dp" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toBottomOf="@id/tvTitleHot3">
                                <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:src="@android:drawable/ic_input_add" app:tint="#FFFFFF" />
                            </com.google.android.material.card.MaterialCardView>
                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="170dp" android:layout_height="wrap_content" android:layout_margin="8dp" app:cardBackgroundColor="#FFFFFF" app:cardCornerRadius="20dp" app:cardElevation="6dp" app:strokeColor="#1A000000" app:strokeWidth="1dp">
                        <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="12dp">
                            <com.google.android.material.card.MaterialCardView android:id="@+id/imgHot4" android:layout_width="match_parent" android:layout_height="130dp" app:cardBackgroundColor="#F5F5F5" app:cardCornerRadius="12dp" app:cardElevation="0dp" app:layout_constraintTop_toTopOf="parent">
                                <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:padding="16dp" android:scaleType="fitCenter" tools:srcCompat="@tools:sample/avatars" />
                            </com.google.android.material.card.MaterialCardView>
                            <ImageView android:layout_width="28dp" android:layout_height="28dp" android:layout_marginTop="8dp" android:layout_marginEnd="8dp" android:padding="6dp" android:src="@android:drawable/ic_menu_myplaces" app:layout_constraintEnd_toEndOf="@+id/imgHot4" app:layout_constraintTop_toTopOf="@+id/imgHot4" app:tint="#FF4B4B" />
                            <TextView android:id="@+id/tvTitleHot4" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:ellipsize="end" android:maxLines="2" android:text="Sản phẩm Hot 4" android:textColor="#333333" android:textSize="14sp" android:textStyle="bold" app:layout_constraintTop_toBottomOf="@id/imgHot4" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="$149.00" android:textColor="#111111" android:textSize="16sp" android:textStyle="bold" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/tvTitleHot4" />
                            <com.google.android.material.card.MaterialCardView android:layout_width="32dp" android:layout_height="32dp" app:cardBackgroundColor="#222222" app:cardCornerRadius="10dp" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toBottomOf="@id/tvTitleHot4">
                                <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:src="@android:drawable/ic_input_add" app:tint="#FFFFFF" />
                            </com.google.android.material.card.MaterialCardView>
                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>
            </HorizontalScrollView>

            <TextView
                android:id="@+id/tvPromoTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="24dp"
                android:text="Khuyến mãi"
                android:textColor="#111111"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/scrollHot" />

            <HorizontalScrollView
                android:id="@+id/scrollPromo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:clipToPadding="false"
                android:paddingHorizontal="12dp"
                android:scrollbars="none"
                app:layout_constraintTop_toBottomOf="@id/tvPromoTitle">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="170dp" android:layout_height="wrap_content" android:layout_margin="8dp" app:cardBackgroundColor="#FFFFFF" app:cardCornerRadius="20dp" app:cardElevation="6dp" app:strokeColor="#1A000000" app:strokeWidth="1dp">
                        <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="12dp">
                            <com.google.android.material.card.MaterialCardView android:id="@+id/imgPromo1" android:layout_width="match_parent" android:layout_height="130dp" app:cardBackgroundColor="#F5F5F5" app:cardCornerRadius="12dp" app:cardElevation="0dp" app:layout_constraintTop_toTopOf="parent">
                                <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:padding="16dp" android:scaleType="fitCenter" tools:srcCompat="@tools:sample/avatars" />
                            </com.google.android.material.card.MaterialCardView>
                            <TextView android:id="@+id/tvTitlePromo1" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:ellipsize="end" android:maxLines="2" android:text="Sản phẩm Sale 1" android:textColor="#333333" android:textSize="14sp" android:textStyle="bold" app:layout_constraintTop_toBottomOf="@id/imgPromo1" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="$59.00" android:textColor="#FF4B4B" android:textSize="16sp" android:textStyle="bold" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/tvTitlePromo1" />
                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="170dp" android:layout_height="wrap_content" android:layout_margin="8dp" app:cardBackgroundColor="#FFFFFF" app:cardCornerRadius="20dp" app:cardElevation="6dp" app:strokeColor="#1A000000" app:strokeWidth="1dp">
                        <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="12dp">
                            <com.google.android.material.card.MaterialCardView android:id="@+id/imgPromo2" android:layout_width="match_parent" android:layout_height="130dp" app:cardBackgroundColor="#F5F5F5" app:cardCornerRadius="12dp" app:cardElevation="0dp" app:layout_constraintTop_toTopOf="parent">
                                <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:padding="16dp" android:scaleType="fitCenter" tools:srcCompat="@tools:sample/avatars" />
                            </com.google.android.material.card.MaterialCardView>
                            <TextView android:id="@+id/tvTitlePromo2" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:ellipsize="end" android:maxLines="2" android:text="Sản phẩm Sale 2" android:textColor="#333333" android:textSize="14sp" android:textStyle="bold" app:layout_constraintTop_toBottomOf="@id/imgPromo2" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="$79.00" android:textColor="#FF4B4B" android:textSize="16sp" android:textStyle="bold" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/tvTitlePromo2" />
                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="170dp" android:layout_height="wrap_content" android:layout_margin="8dp" app:cardBackgroundColor="#FFFFFF" app:cardCornerRadius="20dp" app:cardElevation="6dp" app:strokeColor="#1A000000" app:strokeWidth="1dp">
                        <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="12dp">
                            <com.google.android.material.card.MaterialCardView android:id="@+id/imgPromo3" android:layout_width="match_parent" android:layout_height="130dp" app:cardBackgroundColor="#F5F5F5" app:cardCornerRadius="12dp" app:cardElevation="0dp" app:layout_constraintTop_toTopOf="parent">
                                <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:padding="16dp" android:scaleType="fitCenter" tools:srcCompat="@tools:sample/avatars" />
                            </com.google.android.material.card.MaterialCardView>
                            <TextView android:id="@+id/tvTitlePromo3" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:ellipsize="end" android:maxLines="2" android:text="Sản phẩm Sale 3" android:textColor="#333333" android:textSize="14sp" android:textStyle="bold" app:layout_constraintTop_toBottomOf="@id/imgPromo3" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="$89.00" android:textColor="#FF4B4B" android:textSize="16sp" android:textStyle="bold" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/tvTitlePromo3" />
                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="170dp" android:layout_height="wrap_content" android:layout_margin="8dp" app:cardBackgroundColor="#FFFFFF" app:cardCornerRadius="20dp" app:cardElevation="6dp" app:strokeColor="#1A000000" app:strokeWidth="1dp">
                        <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="12dp">
                            <com.google.android.material.card.MaterialCardView android:id="@+id/imgPromo4" android:layout_width="match_parent" android:layout_height="130dp" app:cardBackgroundColor="#F5F5F5" app:cardCornerRadius="12dp" app:cardElevation="0dp" app:layout_constraintTop_toTopOf="parent">
                                <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:padding="16dp" android:scaleType="fitCenter" tools:srcCompat="@tools:sample/avatars" />
                            </com.google.android.material.card.MaterialCardView>
                            <TextView android:id="@+id/tvTitlePromo4" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:ellipsize="end" android:maxLines="2" android:text="Sản phẩm Sale 4" android:textColor="#333333" android:textSize="14sp" android:textStyle="bold" app:layout_constraintTop_toBottomOf="@id/imgPromo4" />
